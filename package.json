{
  "name": "ANKIT-interview-companion",
  "version": "1.0.0",
  "description": "Always-on-top real-time transparent AI interview overlay assistant.",
  "main": "main.js",
  "scripts": {
    "start": "electron .",
    "pack": "electron-builder --dir",
    "dist": "electron-builder"
  },
  "dependencies": {
    "@google/genai": "^1.2.0",
    "ws": "^8.14.2"
  },
  "devDependencies": {
    "electron": "^41.7.1",
    "electron-builder": "^26.8.1"
  },
  "build": {
    "appId": "com.ANKIT.companion",
    "productName": "ANKITAssistant",
    "mac": {
      "category": "public.app-category.education",
      "target": [
        "dmg",
        "zip"
      ]
    },
    "win": {
      "target": "nsis"
    },
    "linux": {
      "target": [
        "deb",
        "rpm",
        "AppImage"
      ],
      "category": "Education"
    }
  }
}
